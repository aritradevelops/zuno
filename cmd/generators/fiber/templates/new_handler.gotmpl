func fromService{{.Module}}({{.Variable}} *service.{{.Module}}) *{{.Module}} {
	return &{{.Module}}{
		UID: {{.Variable}}.UID,
		{{.FieldsType}}: {{.FieldsType}}{
		},
		CreatedAt: {{.Variable}}.CreatedAt,
		CreatedBy: {{.Variable}}.CreatedBy,
		UpdatedAt: {{.Variable}}.UpdatedAt,
		UpdatedBy: {{.Variable}}.UpdatedBy,
		DeletedAt: {{.Variable}}.DeletedAt,
		DeletedBy: {{.Variable}}.DeletedBy,
	}
}
