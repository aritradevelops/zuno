{{if eq .Adapter.Database.Provider  "mongodb"}}
DATABASE_CONNECTION_URL=mongodb://localhost:27017/{{.PackageBase}}?replicaSet=rs0
{{end}}
{{if eq .Adapter.Database.Provider  "bun"}}
DATABASE_CONNECTION_URL=postgres://postgres:admin@localhost:5432/{{.PackageBase}}?sslmode=disable
{{end}}
HTTP_HOST=localhost
HTTP_PORT=8080