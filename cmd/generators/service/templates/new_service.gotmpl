// Restore implements [{{.ServiceType}}].
func (s *{{.ServiceVariable}}) Restore(ctx context.Context, actor *action.Actor, id uuid.UUID) (bool, error) {
	ok, err := s.{{.RepositoryVariable}}.RestoreByID(ctx, actor, id)
	if err != nil {
