func New{{.ServiceType}}({{.RepositoryVariable}} repository.{{.RepositoryType}}) {{.ServiceType}} {
	return &{{.ServiceVariable}}{
		{{.RepositoryVariable}}: {{.RepositoryVariable}},
	}
}

// List implements [{{.ServiceType}}].
func (s *{{.ServiceVariable}}) List(ctx context.Context, actor *action.Actor, opts *pagination.Options) (*pagination.Result[*{{.Module}}], error) {
	result, err := s.{{.RepositoryVariable}}.List(ctx, actor, opts)
	if err != nil {
		logger.Error().Err(err).Msg("failed to list {{.ReadablePlural}}")
		return nil, ConvertRepositoryError(err)
	}
	{{.VariablePlural}} := make([]*{{.Module}}, len(result.Data))
	for idx, {{.Variable}} := range result.Data {
		{{.VariablePlural}}[idx] = fromRepository{{.Module}}({{.Variable}})
	}

	converted := &pagination.Result[*{{.Module}}]{
		Data: {{.VariablePlural}},
		Info: result.Info,
	}
	return converted, nil
}

// Create implements [{{.ServiceType}}].
func (s *{{.ServiceVariable}}) Create(ctx context.Context, actor *action.Actor, payload {{.FieldsType}}) (*{{.Module}}, error) {
	if err := validation.Validate(payload); err != nil {
		logger.Error().Err(err).Msg("validation failed")
		return nil, NewValidationError("Invalid {{.Readable}} data provided", err)
	}
	{{.Variable}}, err := s.{{.RepositoryVariable}}.Create(ctx, actor, repository.{{.FieldsType}}(payload))
	if err != nil {
		logger.Error().Err(err).Msg("failed to create {{.Readable}}")
		return nil, ConvertRepositoryError(err)
	}
	logger.Info().Msg("{{.Readable}} created successfully!")
	return fromRepository{{.Module}}({{.Variable}}), nil
}

// Update implements [{{.ServiceType}}].
func (s *{{.ServiceVariable}}) Update(ctx context.Context, actor *action.Actor, id uuid.UUID, payload {{.FieldsType}}) (bool, error) {
	if err := validation.Validate(payload); err != nil {
		logger.Error().Err(err).Msg("validation failed")
		return false, NewValidationError("Invalid {{.Readable}} data provided", err)
	}
	ok, err := s.{{.RepositoryVariable}}.UpdateByID(ctx, actor, id, repository.{{.FieldsType}}(payload))
	if err != nil {
		logger.Error().Err(err).Msg("failed to update {{.Readable}}")
		return false, ConvertRepositoryError(err)
	}
	logger.Info().Msg("{{.Readable}} updated successfully!")
	return ok, nil
}

// View implements [{{.ServiceType}}].
func (s *{{.ServiceVariable}}) View(ctx context.Context, actor *action.Actor, id uuid.UUID) (*{{.Module}}, error) {
	{{.Variable}}, err := s.{{.RepositoryVariable}}.FindByID(ctx, actor, id)
	if err != nil {
		logger.Error().Err(err).Msg("{{.Readable}} not found")
		return nil, ConvertRepositoryError(err)
	}
	return fromRepository{{.Module}}({{.Variable}}), nil
}

