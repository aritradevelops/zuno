// Destroy implements [{{.ServiceType}}].
func (s *{{.ServiceVariable}}) Destroy(ctx context.Context, actor *action.Actor, id uuid.UUID) (bool, error) {
	ok, err := s.{{.RepositoryVariable}}.DestroyByID(ctx, actor, id)
	if err != nil {
