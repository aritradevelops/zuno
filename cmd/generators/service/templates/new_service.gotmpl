}

type {{.ServiceType}} interface {
	List(context.Context, *action.Actor, *pagination.Options) (*pagination.Result[*{{.Module}}], error)
	Create(context.Context, *action.Actor, {{.FieldsType}}) (*{{.Module}}, error)
	Update(context.Context, *action.Actor, uuid.UUID, {{.FieldsType}}) (bool, error)
	View(context.Context, *action.Actor, uuid.UUID) (*{{.Module}}, error)
